#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

Adafruit_PWMServoDriver pwm = Adafruit_PWMServoDriver();

// Servo configuration
#define SERVO_MIN 150
#define SERVO_MAX 580
#define NUM_SERVOS 6

// L298N motor pins
#define IN1 12
#define IN2 11
#define IN3 10
#define IN4 9

void setup() {
  Serial.begin(9600);  // Serial from HC-05/HC-12
  pwm.begin();
  pwm.setPWMFreq(50);

  // Motor pin setup
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  Serial.println("Commands:");
  Serial.println("a=0°, b=45°, c=90°, d=135° (Servos)");
  Serial.println("F=Forward, B=Backward, L=Left, R=Right, S=Stop (Car)");

  setAllServos(90);  // Default startup position
  stopCar();         // Car stopped at start
}

void loop() {
  if (Serial.available()) {
    char cmd = Serial.read();
    int angle;

    // Servo Control
    if      (cmd == 'a') angle = 0;
    else if (cmd == 'b') angle = 45;
    else if (cmd == 'c') angle = 90;
    else if (cmd == 'd') angle = 135;
    else angle = -1;

    if (angle != -1) {
      setAllServos(angle);
      Serial.print("Moved servos to ");
      Serial.print(angle);
      Serial.println("°");
      return;
    }

    // Car Control
    switch (cmd) {
      case 'F': forward();  Serial.println("Moving Forward"); break;
      case 'B': backward(); Serial.println("Moving Backward"); break;
      case 'L': left();     Serial.println("Turning Left"); break;
      case 'R': right();    Serial.println("Turning Right"); break;
      case 'S': stopCar();  Serial.println("Stopped"); break;
    }
  }
}

// ----- Servo Control -----
void setAllServos(int angle) {
  int pulse = map(angle, 0, 180, SERVO_MIN, SERVO_MAX);
  for (int ch = 0; ch < NUM_SERVOS; ch++) {
    pwm.setPWM(ch, 0, pulse);
  }
}

// ----- Car Movement -----
void forward() {
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}

void backward() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}

void left() {
  digitalWrite(IN1, 1);
  digitalWrite(IN2, 0);
  digitalWrite(IN3, 0);
  digitalWrite(IN4, 1);
}

void right() {
  digitalWrite(IN1, 0);
  digitalWrite(IN2, 1);
  digitalWrite(IN3, 1);
  digitalWrite(IN4, 0);
}

void stopCar() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

